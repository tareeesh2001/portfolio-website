# ----------------------------------------------------------------------------
# Environment variables for the /api/chat serverless function.
#
# DO NOT put real values in this file or commit secrets to git.
# Add the real values in your hosting platform's dashboard
# (Cloudflare Pages: Settings > Environment variables), or in a local
# ".dev.vars" file when testing with `wrangler pages dev` (also git-ignored).
# ----------------------------------------------------------------------------

# --- OpenAI ---
# Your OpenAI API key (https://platform.openai.com/api-keys).
OPENAI_API_KEY=sk-your-openai-key-here

# --- Google Sheets logging (service account) ---
# All three of these come from the service account JSON key file.

# The service account's client_email.
GOOGLE_CLIENT_EMAIL=your-bot@your-project.iam.gserviceaccount.com

# The service account's private_key. Keep the literal \n escapes exactly as they
# appear in the JSON, and wrap the whole value in quotes.
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvQIBADANBg...\n...\n-----END PRIVATE KEY-----\n"

# The service account's project_id. Note: the Sheets append flow does not use this
# (auth needs only client_email + private_key + sheet id). It is included because it
# ships in the service-account JSON and is useful for identifying the GCP project.
GOOGLE_PROJECT_ID=your-gcp-project-id

# The ID of the target Google Sheet.
# From the URL: https://docs.google.com/spreadsheets/d/THIS_IS_THE_ID/edit
GOOGLE_SHEET_ID=your-google-sheet-id-here

# ----------------------------------------------------------------------------
# Optional
# ----------------------------------------------------------------------------

# Overrides the OpenAI model. Defaults to gpt-4o-mini.
# OPENAI_MODEL=gpt-4o-mini

# The worksheet (tab) name to append rows to. Defaults to "Sheet1".
# SHEET_TAB=Sheet1
