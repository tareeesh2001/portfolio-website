# Files here are NOT uploaded as public static assets.
# (Static-asset uploads serve files publicly, so keep server-only and source files out.)

# Server-side code (runs as the Worker, must not be served publicly as a file)
worker.js
chat-core.js
functions/

# Config & docs
wrangler.toml
.assetsignore
.gitignore
.env.example
.dev.vars
SETUP.md
README.md

# Secrets — never serve a service-account key, even if one is present locally
*service-account*.json
google-credentials*.json
portfolio-website-*.json
*-*.iam.gserviceaccount.com.json

